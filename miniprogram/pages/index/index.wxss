.container {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  /* 默认/滚动状态：动态渐变背景 */
  background: linear-gradient(-45deg, #1a1a2e, #0f3460, #2d1b69, #1a3a4a);
  background-size: 400% 400%;
}

/* 滚动时启动动态渐变动画 */
.container.running,
.container.idle {
  animation: gradientShift 6s ease infinite;
}

/* 停止时静止，分类色层接管 */
.container.stopping,
.container.stopped {
  animation: none;
}

@keyframes gradientShift {
  0%   { background-position: 0% 50%; }
  50%  { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ── 背景色层 ── */
.bg-overlay {
  position: absolute;
  inset: 0;
  transition: background 0.6s ease, opacity 0.6s ease;
}

/* ── emoji 装饰层 ── */
.emoji-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
  transition: opacity 0.5s ease;
}

.emoji { position: absolute; opacity: 0.18; line-height: 1; }
.e1 { top: 60rpx;     left: 30rpx;  transform: rotate(-20deg); font-size: 180rpx; }
.e2 { top: 80rpx;     right: 40rpx; transform: rotate(15deg);  font-size: 140rpx; }
.e3 { bottom: 140rpx; left: 50rpx;  transform: rotate(10deg);  font-size: 150rpx; }
.e4 { bottom: 100rpx; right: 30rpx; transform: rotate(-12deg); font-size: 170rpx; }

/* ── 内容层 ── */
.content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 60rpx;
}

.label-top {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-bottom: 60rpx;
  letter-spacing: 4rpx;
}

/* ── 菜名容器 ── */
.menu-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 60rpx;
  border-radius: 24rpx;
  min-width: 400rpx;
}

.menu-wrap.stopped {
  background: rgba(255, 255, 255, 0.12);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

/* ── 分类标签 ── */
.menu-category {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 4rpx 20rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.menu-wrap.stopped .menu-category {
  color: rgba(255, 255, 255, 0.85);
  background: rgba(255, 255, 255, 0.2);
}

/* ── 菜品名称 ── */
.menu-name {
  font-size: 68rpx;
  font-weight: 700;
  color: #e8e8e8;
  text-align: center;
  line-height: 1.2;
}

.menu-wrap.stopped .menu-name {
  color: #ffffff;
  font-size: 80rpx;
}

/* ── 结果文字 ── */
.result-text {
  margin-top: 36rpx;
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 2rpx;
}

/* ── 底部提示 ── */
.hint-text {
  position: fixed;
  bottom: 100rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 2rpx;
}

/* ── 管理入口 ── */
.admin-btn {
  position: fixed;
  right: 32rpx;
  bottom: 60rpx;
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}

.admin-icon {
  font-size: 36rpx;
  line-height: 1;
}

.admin-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 1rpx;
}

/* ── 空数据 ── */
.empty-wrap {
  position: relative;
  z-index: 10;
  padding: 0 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  text-align: center;
  line-height: 1.8;
}
